@page "/app-list"

@inject ApiService ApiService

<div class="mb-3">
    @if (!showUploadForm)
    {
        <button class="btn btn-primary" @onclick="ShowUploadForm">Upload App</button>
    }
</div>

@if (showUploadForm)
{
    <div class="border rounded p-3 mb-3">
        <h5>Upload App</h5>

        <EditForm Model="uploadRequest" OnValidSubmit="UploadApp">
            <DataAnnotationsValidator />
            <ValidationSummary />

            <div class="row g-3">
                <div class="col-md-6">
                    <label class="form-label">AppName</label>
                    <InputText class="form-control" @bind-Value="uploadRequest.AppName" />
                </div>

                <div class="col-md-6">
                    <label class="form-label">Version</label>
                    <InputText class="form-control" @bind-Value="uploadRequest.Version" />
                </div>

                <div class="col-md-12">
                    <label class="form-label">Description</label>
                    <InputTextArea class="form-control" @bind-Value="uploadRequest.Description" />
                </div>

                <div class="col-md-6">
                    <label class="form-label">FilePath</label>
                    <InputText class="form-control" @bind-Value="uploadRequest.FilePath" />
                </div>

                <div class="col-md-3">
                    <label class="form-label">FileSize</label>
                    <InputNumber class="form-control" @bind-Value="uploadRequest.FileSize" />
                </div>

                <div class="col-md-3">
                    <label class="form-label">Category</label>
                    <InputSelect class="form-select" @bind-Value="uploadRequest.CategoryId">
                        <option value="0">Select Category</option>
                        @foreach (var category in categories)
                        {
                            <option value="@category.CategoryId">@category.CategoryName</option>
                        }
                    </InputSelect>
                </div>
            </div>

            @if (!string.IsNullOrWhiteSpace(uploadMessage))
            {
                <div class="alert alert-info mt-3 mb-0">@uploadMessage</div>
            }

            <div class="mt-3">
                <button type="submit" class="btn btn-success" disabled="@isUploading">
                    @(isUploading ? "Uploading..." : "Save")
                </button>
                <button type="button" class="btn btn-secondary ms-2" @onclick="HideUploadForm" disabled="@isUploading">
                    Cancel
                </button>
            </div>
        </EditForm>
    </div>
}

@if (response.IsSuccess)
{
    <table class="table table-responsive">
        <thead>
            <tr>
                <th>No.</th>
                <th>AppName</th>
                <th>Description</th>
                <th>Version</th>
                <th>FileSize</th>
                <th>Status</th>
                <th>CreatedAt</th>
                <th>Category</th>
                <th>Download</th>
            </tr>
        </thead>
        <tbody>
            @if (response.Data is not null)
            {
                rowNo = 0;
                foreach (var item in response.Data.Apps)
                {
                    <tr>
                        <td>@(++rowNo)</td>
                        <td>@item.AppName</td>
                        <td>@item.Description</td>
                        <td>@item.Version</td>
                        <td>@item.FileSize</td>
                        <td>@item.Status</td>
                        <td>@item.CreatedAt</td>
                        <td>@item.CategoryName</td>
                        <td>@item.DownloadCount</td>
                    </tr>
                }
            }
        </tbody>
    </table>
}
